#commands to quality trim paired end Illumina reads; merge pairs where there is an overlap and generate fastq and fasta files consisting of merged reads concatenated with R1 from pairs that were not merged of where R2 failed quality screening
set -o xtrace
#Input flags 
#-1 Reads 1 fastq
#-2 Reads 2 fastq


print_usage() {
  printf "Usage: ..."
}

while getopts '1:2:' flag; do
  case "${flag}" in
    1) R1="${OPTARG}" ;;
    2) R2="${OPTARG}" ;;    
    *) print_usage
       exit 1 ;;
  esac
done



#Clean reads
echo "Reads" $R1 $R2
echo "trimmomatic value within MERGE" $trimmomatic

if [ -f "$R2" ]; then
eval "$trimmomatic PE $R1 $R2 \
 R1_paired.fastq R1_unpaired.fastq R2_paired.fastq R2_unpaired.fastq ILLUMINACLIP:/gpfs/home/e130/trimmomatic/adapters/novogene.fa:2:30:10:2:True LEADING:3 TRAILING:3 SLIDINGWINDOW:4:15 MINLEN:36"

#Merge pairs
usearch -fastq_mergepairs R1_paired.fastq -reverse R2_paired.fastq -fastqout merged.fq -fastqout_notmerged_fwd notmerged_R1.fq -fastqout_notmerged_rev notmerged_R2.fq -threads 48

#concatenate merged reads and R1 from non merged and unpaired reads
cat merged.fq notmerged_R1.fq R1_unpaired.fastq > temp.fastq

else

eval "$trimmomatic SE $R1 \
 temp.fastq ILLUMINACLIP:/gpfs/home/e130/trimmomatic/adapters/novogene.fa:2:30:10:2:True LEADING:3 TRAILING:3 SLIDINGWINDOW:4:15 MINLEN:36"


fi

#generate fasta file
eval $seqkit fq2fa temp.fastq > temp.fasta

# remove sequences shorter than 100 bases


eval $seqkit seq -g -m 100 temp.fastq> tempx.fastq
eval $seqkit fq2fa tempx.fastq > tempx.fasta
